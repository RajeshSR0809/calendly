model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  slug      String   @unique
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventTypes        EventType[]
  availabilityRules AvailabilityRule[]

  @@map("users")
}
